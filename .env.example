# Copy to .env (gitignored) and fill in. Consumed by scripts/native-tests.sh,
# which forwards these to the windows-gnu test process via WSLENV.

# Required only for the LLM-as-judge native test (native_window_passes_llm_vision_judge).
OPENAI_API_KEY=

# Optional judge knobs. Defaults if unset: native test → gpt-5.4-mini, e2e
# judge → gpt-5.4-nano. Setting OPENAI_JUDGE_MODEL below overrides BOTH.
# Menu (current 2026-05, in→out $/1M): gpt-5.5 ($5→$30, flagship),
# gpt-5.4 ($2.50→$15), gpt-5.4-mini ($0.75→$4.50), gpt-5.4-nano ($0.20→$1.25),
# gpt-4o ($2.50→$10, legacy). Avoid gpt-4o-mini — it false-fails a correct
# render (can't resolve the ~20px text inset). GPT-5.x are reasoning models;
# the test/fixture pick the right request shape automatically.
# OPENAI_JUDGE_MODEL=gpt-5.4-mini
# OPENAI_JUDGE_EFFORT=low      # 5.x reasoning effort: low|medium|high (native test only)
# OPENAI_JUDGE_DETAIL=low      # "low" = ~85-token tile (cheap, still correct); "high" = tiled/precise
# OPENAI_JUDGE_SCALE=1.0       # downscale the PNG before sending (1.0 = full res)

# Optional: dump the captured popup window to this WINDOWS path (note backslashes).
# NUDGE_DUMP_PNG=C:\Users\you\Downloads\nudge_capture.png
